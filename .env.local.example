# Aruba captive portal POST target (browser submits the hidden form here)
NEXT_PUBLIC_ARUBA_ACTION=http://securelogin.arubanetworks.com/swarm.cgi

# Credentials injected on the server into the portal page (sent with the Aruba form POST)
ARUBA_USER=guest
ARUBA_PASSWORD=Admin123

# Internal backend that stores guest registration (used only by Next.js API route)
WIFI_SAVE_ENDPOINT=http://10.150.1.47/Wifi/SaveAndConnect
